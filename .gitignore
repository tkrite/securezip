################################################################################
# マルチエージェント開発環境用 .gitignore
# Git Worktree + Claude Code環境に最適化
################################################################################

#===============================================================================
# Claude Code 関連
#===============================================================================
# Claude Code設定は共有するため、.claudeディレクトリは除外しない
# ただし、ローカル固有の設定がある場合は以下に追加
.claude/local/
.claude/*.local.*
.claude/.cache/

#===============================================================================
# マルチエージェント開発 - ログ・作業ファイル
#===============================================================================
# 個人作業ログ（日付付きログは保持、個人メモは除外）
Documents/logs/development/*.tmp
Documents/logs/development/*.draft
Documents/logs/development/*.personal
Documents/logs/amendment/*.tmp
Documents/logs/amendment/*.draft

# エージェント一時ファイル
Documents/analysis/*.tmp
Documents/analysis/*.working
Documents/analysis/.cache/

# マージコンフリクトバックアップ
*.orig
*.rej
*.BACKUP.*
*.BASE.*
*.LOCAL.*
*.REMOTE.*

# Worktree固有の一時ファイル
.worktree-*
*.worktree-lock

#===============================================================================
