#===============================================================================
# テスト関連
#===============================================================================
# テスト結果（保持したい場合はコメントアウト）
# Documents/test_results/*.xml
# Documents/test_results/*.json

# テスト用一時ファイル
test-results/
test-output/
*.test.tmp
*.spec.tmp

#===============================================================================
# Git Worktree 特有の除外
#===============================================================================
# Worktree作成時の一時ファイル
.git-worktree-*

# 各Worktreeのローカル設定
.worktree-config
*.worktree.local

#===============================================================================
# サンプルディレクトリ関連
#===============================================================================
# samplesディレクトリへのシンボリックリンク（使用する場合）
samples-link
samples-link/

# ローカルにコピーしたサンプル
Documents/samples/*.local.*
Documents/samples/temp/

#===============================================================================
# プロジェクト固有の追加設定
#===============================================================================
# 以下にプロジェクト固有の除外パターンを追加

#===============================================================================
# SecureZip - Xcode / Swift プロジェクト
#===============================================================================
# Google OAuth 設定ファイル（機密情報を含むため除外）
SecureZip/SecureZip/Resources/GoogleService-Info.plist
**/GoogleService-Info.plist

# Xcode ビルド成果物・派生データ
SecureZip/*.xcodeproj/xcuserdata/
SecureZip/*.xcodeproj/project.xcworkspace/xcuserdata/
SecureZip/*.xcworkspace/xcuserdata/
SecureZip/DerivedData/
SecureZip/*.xcscmblueprint
SecureZip/*.xccheckout
SecureZip/build/

# Swift Package Manager キャッシュ
SecureZip/.build/
SecureZip/.swiftpm/

# Xcode ユーザー固有設定
*.xcuserstate
*.xcuserdatad/

# Archive / Export
SecureZip/*.xcarchive
SecureZip/ExportOptions.plist